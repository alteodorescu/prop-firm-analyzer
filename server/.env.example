# ═══════════════════════════════════════════════════════════
# Prop Firm Automation Server — Configuration
# ═══════════════════════════════════════════════════════════

# Supabase (same as the frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Data Feed: "mock" | "dxfeed" | "databento"
FEED_TYPE=mock

# Databento bridge (when FEED_TYPE=databento)
# Start the Python bridge first: DATABENTO_API_KEY=your_key python feed-bridge.py
DATABENTO_BRIDGE_PORT=3002

# dxFeed connection (when FEED_TYPE=dxfeed)
DXFEED_WS_URL=wss://your-dxfeed-endpoint
DXFEED_AUTH_TOKEN=your_dxfeed_token

# Trading symbol (NQ futures)
# Databento: NQ.c.0 (continuous front month) or NQM6 (specific contract)
# dxFeed: /NQM26
SYMBOL=NQ.c.0

# ORB Session Windows (UTC times, HH:MM format)
LONDON_OR_START=08:00
LONDON_OR_END=08:15
NY_OR_START=14:30
NY_OR_END=14:45

# ORB Strategy Parameters
ORB_TARGET_MULTIPLIER=1.0
ORB_MAX_RISK_POINTS=40
TICK_VALUE=5.00
POINT_VALUE=20.00

# PickMyTrade Execution
PICKMYTRADE_ENABLED=false
PICKMYTRADE_WEBHOOK_URL=https://api.pickmytrade.trade/v2/add-trade-data-latest

# Server
PORT=3001
